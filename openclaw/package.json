{
  "name": "arkadia-openclaw-gateway",
  "version": "1.0.0",
  "description": "OpenClaw execution gateway for the Arkadia Oracle sovereign cloud agentic system",
  "private": true,
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "start": "openclaw start --config config.json",
