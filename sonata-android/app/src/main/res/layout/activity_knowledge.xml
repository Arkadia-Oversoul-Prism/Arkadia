<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="12dp"
        android:background="@color/bg_dark">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◈ KNOWLEDGE OS"
            android:textColor="@color/accent_teal"
            android:textSize="18sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Arkadia Intelligence Systems · Prism"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A00D4AA" />

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/knowledgeFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavKnowledge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        app:itemIconTint="@color/nav_tint"
        app:itemTextColor="@color/nav_tint"
        app:menu="@menu/bottom_nav_knowledge" />

</LinearLayout>
