<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Search mode label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MODE"
        android:textColor="@color/text_dim"
        android:textSize="9sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerSearchMode"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="12dp" />

    <!-- Query row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <EditText
            android:id="@+id/etSearchQuery"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_dim"
            android:hint="Search the vault…"
            android:textSize="13sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSearch"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="⟐"
            android:textSize="18sp"
            android:backgroundTint="@color/accent_teal"
            android:textColor="@color/bg_dark"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/tvSearchStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter a query above"
        android:textColor="@color/text_dim"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp" />

    <!-- Results -->
    <ScrollView
        android:id="@+id/searchScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/searchResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
