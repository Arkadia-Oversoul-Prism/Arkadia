<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Overlay permission banner -->
        <TextView
            android:id="@+id/bannerOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/accent_warm"
            android:text="Tap to enable floating player (Display over other apps)"
            android:textColor="@color/bg_dark"
            android:textSize="12sp"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SONATA"
            android:textColor="@color/accent_teal"
            android:textSize="32sp"
            android:letterSpacing="0.3"
            android:fontFamily="monospace"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oracle Voice · Arkadia Intelligence Systems"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="32dp" />

        <!-- Voice selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VOICE"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerVoice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input"
            android:layout_marginBottom="24dp" />

        <!-- Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SPEED"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvSpeedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0×"
                android:textColor="@color/accent_teal"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/accent_teal"
            android:thumbTint="@color/accent_teal"
            android:layout_marginBottom="24dp" />

        <!-- Test input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST PHRASE"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTestInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_dim"
            android:hint="Enter text to speak…"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Playback controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnSpeak"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="▶ Speak"
                android:backgroundTint="@color/accent_teal"
                android:textColor="@color/bg_dark" />

            <Button
                android:id="@+id/btnPause"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Pause"
                android:enabled="false" />

            <Button
                android:id="@+id/btnStop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop"
                android:enabled="false" />
        </LinearLayout>

        <!-- Settings -->
        <Button
            android:id="@+id/btnSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙ Settings"
            android:textColor="@color/text_dim" />

        <!-- Knowledge OS -->
        <Button
            android:id="@+id/btnKnowledgeOs"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="◈  KNOWLEDGE OS"
            android:textColor="@color/accent_teal"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <!-- Tip -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip: Select any text in any app → Share/More → Speak with Sonata"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="24dp"
            android:gravity="center" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
