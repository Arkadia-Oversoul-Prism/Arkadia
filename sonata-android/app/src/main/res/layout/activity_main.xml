<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Overlay permission banner -->
        <TextView
            android:id="@+id/bannerOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/accent_warm"
            android:text="Tap to enable floating player"
            android:textColor="@color/bg_dark"
            android:textSize="12sp"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- API Key Status -->
        <TextView
            android:id="@+id/tvApiStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:textColor="@color/accent_warm"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SONATA"
            android:textColor="@color/accent_teal"
            android:textSize="32sp"
            android:letterSpacing="0.3"
            android:fontFamily="monospace"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ElevenLabs Reader · Arkadia"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

        <!-- Playback bar (shows when playing) -->
        <LinearLayout
            android:id="@+id/playbackBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone">

            <!-- Playback controls row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnPlayPause"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="⏸"
                    android:textSize="18sp"
                    android:padding="0dp"
                    android:backgroundTint="@color/accent_teal"
                    android:textColor="@color/bg_dark" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <SeekBar
                        android:id="@+id/seekProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progressTint="@color/accent_teal"
                        android:thumbTint="@color/accent_teal"
                        android:max="100" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvTimeElapsed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0:00"
                            android:textColor="@color/text_dim"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvTimeTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="@color/text_dim"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnStop"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/text_dim" />
            </LinearLayout>
        </LinearLayout>

        <!-- Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SPEED"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvSpeedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0×"
                android:textColor="@color/accent_teal"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/accent_teal"
            android:thumbTint="@color/accent_teal"
            android:layout_marginBottom="24dp" />

        <!-- Text input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEXT"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTestInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_dim"
            android:hint="Paste or type text to read aloud…"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Speak button -->
        <Button
            android:id="@+id/btnSpeak"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶ READ ALOUD"
            android:textSize="14sp"
            android:letterSpacing="0.15"
            android:backgroundTint="@color/accent_teal"
            android:textColor="@color/bg_dark"
            android:layout_marginBottom="24dp" />

        <!-- Settings -->
        <Button
            android:id="@+id/btnSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙ Settings &amp; API Keys"
            android:textColor="@color/text_dim" />

        <!-- Knowledge OS -->
        <Button
            android:id="@+id/btnKnowledgeOs"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="◈  KNOWLEDGE OS"
            android:textColor="@color/accent_teal"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
