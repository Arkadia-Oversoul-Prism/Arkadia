# ── Arkadia Oracle — Environment Variables ────────────────────────────────────
# Copy relevant vars into your Render / Railway / Vercel dashboard.
# NEVER commit real values. These are reference keys only.

# ── Core AI ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here
# Get a free key at: https://aistudio.google.com/app/apikey

# ── GitHub Corpus Sync ────────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
# Grants Oracle read access to the Arkadia repo for corpus auto-sync.
# Create at: https://github.com/settings/tokens (scope: repo read)

# ── Sovereign Access ──────────────────────────────────────────────────────────
SOVEREIGN_KEY=arkadia-forge-2026
# Override this in production with a strong unique secret.

# ── Firebase (optional — enables persistent state via Firestore) ──────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Full JSON string of your Firebase service account key.
# Download from: Firebase Console → Project Settings → Service Accounts
# When set, jobs and goals survive Render free-tier restarts via Firestore.

# ── Telegram Bot (optional — OpenClaw trigger) ────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Create a bot via @BotFather on Telegram. Free.

# ── Webhook Security (optional) ───────────────────────────────────────────────
WEBHOOK_SECRET=your_webhook_hmac_secret_here
# Used to verify incoming webhook payloads from OpenClaw / external triggers.

# ── Kernel Tuning ─────────────────────────────────────────────────────────────
SOLSPIRE_WORKERS=2
# Number of background kernel worker threads (default: 2)
SOLSPIRE_GOAL_TICK_SECONDS=15
# How often the goal scheduler checks for due goals (default: 15s)
SOLSPIRE_DATA_DIR=data
# Directory for local JSON snapshots (Render ephemeral disk — use Firebase for durability)

# ── Autonomous Weaver ─────────────────────────────────────────────────────────
ARKADIA_RECURSIVE_ENABLED=false
ARKADIA_RECURSIVE_DEPTH=3
ARKADIA_RECURSIVE_INTERVAL=1.0
